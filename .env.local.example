# ── Frontend environment ──────────────────────────────────────────────────────
# Copy to .env.local and adjust.

# Base URL of the Laravel API. LEAVE EMPTY to run the storefront on built-in mock
# data (no backend required). Set it to switch every page to the live API.
#   e.g. http://localhost:8000/api   (local)   |   https://api.rupkothatrendz.com/api  (prod)
NEXT_PUBLIC_API_URL=

# Public site URL (used for metadata / canonical / sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp number for the floating chat button
NEXT_PUBLIC_WHATSAPP_NUMBER=+8801712345678
